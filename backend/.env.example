APP_NAME=LiveBrief API
APP_ENV=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|10\.\d+\.\d+\.\d+|192\.168\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+):5174
DEFAULT_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
EXTRACTOR_MODE=ai
REQUEST_TIMEOUT_SECONDS=45
ARTICLE_TIMEOUT_SECONDS=20
MAX_ARTICLES=10
MAX_ARTICLE_CHARS=50000
MAX_DOWNLOAD_BYTES=5000000
